<Window x:Class="RankingDemo.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:RankingDemo.Wpf.ViewModels"
        mc:Ignorable="d"
        Title="Ranking Demo" Height="650" Width="1000">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <DockPanel Margin="12">
        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal">
                <Button Content="CSV betöltése" Padding="12,6" Command="{Binding LoadCsvCommand}" />
                <TextBlock Margin="12,0,0,0" VerticalAlignment="Center" Text="Lekérdezés:" />
                <ComboBox Width="320"                          
                            Margin="8,0,0,0"
                            ItemsSource="{Binding Queries}"
                            SelectedItem="{Binding SelectedQuery}"
                            IsEditable="True"
                            IsReadOnly="True"
                            Text="{Binding SelectedQuery, TargetNullValue=Töltsön be egy .csv fájlt}"
                            HorizontalAlignment="Center"/>
                <TextBlock Text="k:" VerticalAlignment="Center" Margin="12,0,0,0"/>

                <TextBox Width="40"
                    Margin="8,0,0,0"
                    Text="{Binding K}"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    TextAlignment="Center"/>

                <TextBlock Margin="12,0,0,0" VerticalAlignment="Center" Text="Módszer:" />
                <ComboBox Width="160" Margin="8,0,0,0"
                  ItemsSource="{Binding Algorithms}"
                  SelectedItem="{Binding SelectedAlgorithm}" />

                <Button Content="Tanítás" Margin="12,0,0,0" Padding="12,6"
                Command="{Binding TrainSelectedCommand}" />
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                <TextBlock Text="Precision@k:" FontWeight="Bold"/>
                <TextBlock Text="{Binding PrecisionAtKValue, StringFormat=F2}" Margin="6,0,12,0"/>
                <TextBlock Text="NDCG@k:" FontWeight="Bold"/>
                <TextBlock Text="{Binding NdcgAtKValue, StringFormat=F2}" Margin="6,0,0,0"/>
            </StackPanel>
        </StackPanel>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <GroupBox Header="Eredeti lista (adatból)" Grid.Row="0" Margin="0,0,0,8">
                <DataGrid ItemsSource="{Binding RowsForSelectedQuery}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="DocId" Binding="{Binding DocId}" Width="120"/>
                        <DataGridTextColumn Header="Relevance" Binding="{Binding Relevance}" Width="90"/>
                        <DataGridTextColumn Header="DocText" Binding="{Binding DocText}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </GroupBox>

            <GroupBox Header="Kiválasztott modell rangsora" Grid.Row="1" Margin="0,0,0,8">
                <DataGrid ItemsSource="{Binding RankedRows}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="DocId" Binding="{Binding DocId}" Width="120"/>
                        <DataGridTextColumn Header="Score" Binding="{Binding Score}" Width="90"/>
                        <DataGridTextColumn Header="Relevance" Binding="{Binding Relevance}" Width="90"/>
                        <DataGridTextColumn Header="DocText" Binding="{Binding DocText}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </GroupBox>

            <GroupBox Header="Módszerek összehasonlítása" Grid.Row="2">
                <DataGrid ItemsSource="{Binding MetricResults}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  IsReadOnly="True"
                  Height="140">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Módszer" Binding="{Binding Algorithm}" Width="*" />
                        <DataGridTextColumn Header="Precision@k" Binding="{Binding PrecisionAtK, StringFormat=F2}" Width="120" />
                        <DataGridTextColumn Header="NDCG@k" Binding="{Binding NdcgAtK, StringFormat=F2}" Width="120" />
                    </DataGrid.Columns>
                </DataGrid>
            </GroupBox>
        </Grid>
    </DockPanel>
</Window>